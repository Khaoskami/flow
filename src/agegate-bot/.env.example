# ===========================================
# AgeGate Bot Configuration
# ===========================================

# Required — Discord bot token
DISCORD_TOKEN=

# Bot Settings
BOT_PREFIX=!
VERIFIED_ROLE=Verified 18+
VERIFY_CHANNEL=age-verification
LOG_CHANNEL=verification-logs
MIN_AGE=18

# Security
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
RETENTION_HOURS=24

# Analysis Tuning
TAMPER_THRESHOLD=0.60
OCR_CONFIDENCE=0.35
MAX_ATTEMPTS=3
COOLDOWN_MINUTES=10

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET=
WEB_BASE_URL=http://localhost:8080
API_MASTER_KEY=

# Legal Document
ORG_NAME=AgeGate Verification Services
LEGAL_CONTACT_EMAIL=legal@example.com
